/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model stripe_webhook_events {
  id                 String                       @id @db.VarChar(255)
  event_type         String                       @db.VarChar(100)
  stripe_object_id   String                       @db.VarChar(255)
  stripe_object_type String                       @db.VarChar(100)
  application_id     BigInt?
  processed_at       DateTime                     @default(now()) @db.Timestamp(0)
  status             stripe_webhook_events_status @default(processed)
  metadata           String?                      @db.LongText

  @@index([application_id], map: "idx_application")
  @@index([processed_at], map: "idx_processed_at")
  @@index([stripe_object_id], map: "idx_stripe_object")
}

enum stripe_webhook_events_status {
  processed
  failed
  duplicate
}
